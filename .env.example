# ── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h

# ── Login credentials (family shared account) ────────────────────────────────
BASIC_USERNAME=family
BASIC_PASSWORD=yourpassword

# ── Google Sheets (service account) ─────────────────────────────────────────
# Share the spreadsheet with this email address (Editor permission)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key from the service account JSON key file.
# Replace literal newlines with \n
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=1CGCxHNYaJ8bMJBwj3urLdduMH0uFDjs-kRXHv59NmMc

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# In development this is empty (Vite proxy handles /api).
# In production set this to your server URL.
VITE_API_URL=
