{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://japanese101-pet/schemas/kana.schema.json",
  "title": "Kana",
  "type": "object",
  "required": ["kana"],
  "properties": {
    "kana": {
      "type": "array",
      "items": { "$ref": "#/definitions/KanaEntry" }
    }
  },
  "definitions": {
    "KanaEntry": {
      "type": "object",
      "required": ["id", "hiragana", "katakana", "romaji", "row", "type", "difficulty"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string", "pattern": "^[a-z_]+$" },
        "hiragana":  { "type": "string", "minLength": 1, "maxLength": 2 },
        "katakana":  { "type": "string", "minLength": 1, "maxLength": 2 },
        "romaji":    { "type": "string", "pattern": "^[a-z]+$" },
        "row":       {
          "type": "string",
          "enum": ["vowel","k","s","t","n","h","m","y","r","w","n_single","g","z","d","b","p"]
        },
        "type":      { "type": "string", "enum": ["seion","dakuon","handakuon","youon"] },
        "difficulty":{ "type": "integer", "minimum": 1, "maximum": 3 }
      }
    }
  }
}
