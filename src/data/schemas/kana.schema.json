{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KanaList",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "hiragana", "katakana", "romaji", "row", "type", "difficulty"],
    "properties": {
      "id": { "type": "string" },
      "hiragana": { "type": "string" },
      "katakana": { "type": "string" },
      "romaji": { "type": "string" },
      "row": { "type": "string" },
      "type": { "type": "string", "enum": ["seion", "dakuon", "handakuon", "youon"] },
      "difficulty": { "type": "integer", "minimum": 1, "maximum": 3 }
    },
    "additionalProperties": false
  }
}
