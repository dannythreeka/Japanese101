{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VocabularyList",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "kana", "romaji", "meaning_zh", "category", "unit", "image", "audio"],
    "properties": {
      "id": { "type": "string" },
      "kana": { "type": "string" },
      "romaji": { "type": "string" },
      "meaning_zh": { "type": "string" },
      "category": { "type": "string" },
      "unit": { "type": "string" },
      "emoji": { "type": "string" },
      "image": {
        "type": "object",
        "required": ["src", "license", "source_url"],
        "properties": {
          "src": { "type": "string" },
          "license": { "type": "string" },
          "source_url": { "type": "string" }
        },
        "additionalProperties": false
      },
      "audio": {
        "type": "object",
        "required": ["src", "origin"],
        "properties": {
          "src": { "type": "string" },
          "origin": { "type": "string", "enum": ["tts_generated", "recorded"] }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
