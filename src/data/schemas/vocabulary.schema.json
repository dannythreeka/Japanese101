{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://japanese101-pet/schemas/vocabulary.schema.json",
  "title": "Vocabulary",
  "type": "object",
  "required": ["words"],
  "properties": {
    "words": {
      "type": "array",
      "items": { "$ref": "#/definitions/Word" }
    }
  },
  "definitions": {
    "Word": {
      "type": "object",
      "required": ["id", "kana", "romaji", "meaning_zh", "category", "image", "audio"],
      "additionalProperties": false,
      "properties": {
        "id":         { "type": "string", "pattern": "^w_[a-z0-9_]+$" },
        "kana":       { "type": "string", "minLength": 1 },
        "romaji":     { "type": "string", "pattern": "^[a-z ]+$" },
        "meaning_zh": { "type": "string", "minLength": 1 },
        "category":   { "type": "string" },
        "unit":       { "type": "string", "description": "可選:課本進度索引代碼" },
        "emoji":      { "type": "string", "description": "代表詞語的 emoji 字元，用於遊戲中心顯示區" },
        "source":     {
          "type": "string",
          "enum": ["mitsumura_content", "mitsumura_qr", "extended"],
          "description": "詞彙來源:mitsumura_content=光村課本詞彙列表、mitsumura_qr=光村QR練習詞、extended=課外補充詞(常見日語基礎詞,無版權問題)"
        },
        "image":      { "$ref": "#/definitions/Asset" },
        "audio":      { "$ref": "#/definitions/Asset" }
      }
    },
    "Asset": {
      "type": "object",
      "required": ["src", "license"],
      "additionalProperties": false,
      "properties": {
        "src":        { "type": "string" },
        "license":    {
          "type": "string",
          "enum": ["CC0","CC-BY","CC-BY-SA","self-created","tts_generated","public_domain","VOICEVOX_四国めたん"]
        },
        "source_url": { "type": "string", "format": "uri" },
        "origin":     { "type": "string", "description": "tts_generated / recorded / drawn" }
      }
    }
  }
}
